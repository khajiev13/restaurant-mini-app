# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret

# Public URL for the app. Leave blank for Quick Tunnel mode; start.sh updates it.
PUBLIC_APP_URL=

# Optional: set this to a stable custom domain such as https://restaurant.labtutor.app
# and provide CLOUDFLARE_TUNNEL_TOKEN below to use a named Cloudflare Tunnel.
# Named tunnels are the production-ready path. Leave both blank only for temporary Quick Tunnel testing.
CLOUDFLARE_TUNNEL_TOKEN=

# Optional hardening overrides. Leave blank unless you need to widen the defaults.
# Comma-separated values, for example: https://admin.example.com,https://staging.example.com
CORS_ALLOWED_ORIGINS=
TRUSTED_HOSTS=

# AliPOS API
ALIPOS_API_CLIENT_ID=your-alipos-client-id
ALIPOS_API_CLIENT_SECRET=your-alipos-client-secret
ALIPOS_API_BASE_URL=https://web.alipos.uz

# Yandex Maps
YANDEX_MAPS_API_KEY=
YANDEX_GEOSUGGEST_API_KEY=

# PostgreSQL
POSTGRES_USER=restaurant_user
POSTGRES_PASSWORD=your-strong-password
POSTGRES_DB=restaurant_db

# JWT
JWT_SECRET=your-64-char-hex-string

# Multicard / Rahmat payment gateway
# Sandbox: application_id=rhmt_test, secret=Pw18axeBFo8V7NamKHXX, store_id=6
# Production base URL: https://mesh.multicard.uz
MULTICARD_API_BASE_URL=https://dev-mesh.multicard.uz
MULTICARD_APPLICATION_ID=
MULTICARD_SECRET=
MULTICARD_STORE_ID=0

# Frontend uses the same origin as the API in Docker. Leave blank.
VITE_API_BASE_URL=
